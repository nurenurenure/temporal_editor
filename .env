# Настройки базы данных PostgreSQL
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal
POSTGRES_DB=temporal

# Путь к папке воркфлоу на хост-машине (Windows/Linux)
HOST_WORKFLOWS_DIR=./workflows

# Внешние порты для локальной разработки
DB_PORT=5432
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8233
BACKEND_PORT=8080
FRONTEND_PORT=80